{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "cd admin && npm run build",
  "outputDirectory": "admin/.next",
  "installCommand": "cd admin && npm install",
  "devCommand": "cd admin && npm run dev",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://amoha-backend-v2.onrender.com/api/:path*"
    }
  ]
}
